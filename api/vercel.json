{
  "version": 2,
  "functions": {
    "api/media.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(audio|images)/(.*)",
      "dest": "/api/media?type=$1&file=$2"
    },
    {
      "src": "/(audio|images)/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/public/$1/$2"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        }
      ]
    }
  ]
}